---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteBase } from '../utils/paths';

const base = siteBase();
---

<BaseLayout
  title="404 — Página no encontrada"
  titleEn="404 — Page not found"
  description="La página que buscas no existe en Clima México."
  descriptionEn="The page you are looking for does not exist on Clima México."
  lang="es"
  robots="noindex,follow"
>
  <main class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <div class="max-w-2xl mx-auto px-4 py-16 space-y-6 text-center">
      <p class="text-8xl font-extrabold tracking-tighter text-blue-600 dark:text-blue-400">404</p>
      <h1
        class="text-2xl font-bold tracking-tight sm:text-3xl"
        data-i18n-en="Page not found"
      >
        Página no encontrada
      </h1>
      <p
        class="text-gray-600 dark:text-gray-400 leading-relaxed"
        data-i18n-en="The page you requested does not exist or may have been moved."
      >
        La página que solicitaste no existe o puede haber cambiado de dirección.
      </p>

      <nav aria-label="Páginas principales" class="flex flex-wrap justify-center gap-3 pt-4">
        <a
          href={base}
          class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-blue-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
          data-i18n-en="Home"
        >
          Inicio
        </a>
        <a
          href={`${base}mapa/`}
          class="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200 dark:hover:bg-gray-800"
          data-i18n-en="Map"
        >
          Mapa
        </a>
        <a
          href={`${base}clima/`}
          class="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200 dark:hover:bg-gray-800"
          data-i18n-en="City catalogue"
        >
          Catálogo de ciudades
        </a>
        <a
          href={`${base}pregunta/`}
          class="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200 dark:hover:bg-gray-800"
          data-i18n-en="Ask"
        >
          Pregunta
        </a>
      </nav>
    </div>
  </main>
</BaseLayout>
