---
/**
 * ES/EN language toggle — Story 6.1.
 *
 * Click swaps sessionStorage 'mw:lang' between 'es' and 'en' and
 * reloads the page so the inline-pre-paint script in BaseLayout
 * applies the new lang to <html> + swaps known [data-i18n-en]
 * text nodes.
 *
 * Visually: a two-state pill ES | EN, current language emphasized.
 */
---

<button
  id="lang-toggle-btn"
  type="button"
  aria-label="Cambiar idioma"
  title="Cambiar idioma"
  class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-300 text-xs font-semibold text-gray-700 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
>
  {/* Shows the OTHER language as the action label ("EN" when current
      is ES, "ES" when current is EN). Compact enough to fit beside
      the theme toggle on a 360 px mobile viewport. */}
  <span id="lang-toggle-label">EN</span>
</button>

<script>
  import { readLang, writeLang, type Lang } from '../../lib/lang';

  function refreshLabel(lang: Lang): void {
    const label = document.getElementById('lang-toggle-label');
    if (!label) return;
    label.textContent = lang === 'en' ? 'ES' : 'EN';
  }

  refreshLabel(readLang());

  const btn = document.getElementById('lang-toggle-btn');
  btn?.addEventListener('click', () => {
    const next: Lang = readLang() === 'en' ? 'es' : 'en';
    writeLang(next);
    // Reload so the inline pre-paint script in BaseLayout applies
    // the new lang to <html> + swaps the i18n text nodes before any
    // user-visible paint.
    location.reload();
  });
</script>
